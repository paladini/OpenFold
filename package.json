{
  "name": "openfold",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/* run build",
    "test": "pnpm -r --filter=./packages/* --filter=./apps/* run test -- run",
    "typecheck": "pnpm -r --filter=./packages/* --filter=./apps/* run typecheck",
    "lint": "pnpm -r --filter=./packages/* --filter=./apps/* run lint"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.61.1",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.19.0",
    "harness-score": "^1.3.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  }
}
